<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Allow cleartext for development (Metro) but ensure system CAs are trusted for HTTPS -->
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>

  <!-- Ensure the API domain uses system trust anchors for TLS -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">customer.spectrasolar.co.uk</domain>
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </domain-config>
</network-security-config>
